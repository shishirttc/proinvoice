<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /proinvoice/

  # 1. API Calls: handle /proinvoice/api/...
  RewriteRule ^api/(.*)$ api.php/$1 [L,QSA]
  RewriteRule ^api$ api.php [L,QSA]

  # 2. Static Files: if it's a real file or folder, serve it
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 3. SPA Routing: everything else to index.html
  RewriteRule ^ index.html [L]
</IfModule>